# Template for environment files. Copy this to .env.local, .env.preview,
# .env.prod, etc. Example: `cp .env.example .env.local` then fill in real
# values. These files are git-ignored.
#
# Every variable referenced from docker-compose-backend.yml or
# docker-compose-frontend.yml is enumerated here, with its default value
# shown alongside. Variables annotated `(required)` have no default —
# the stack won't start if they're missing.

# --- Spring profile (matches application-<profile>.properties) ---
# Common values: local, dev, prod. Leave empty for the default profile.
SPRING_PROFILES_ACTIVE=local

# --- Compose profiles (comma-separated) ---
# `quality` brings up SonarQube. Leave empty in dev/prod where you don't want it.
COMPOSE_PROFILES=

# ============================================================
# Frontend
# ============================================================

# FRONTEND_MODE selects what the frontend container runs:
#   dev     → Vite dev server on FRONTEND_PORT (HMR, reads source directly)
#   preview → Vite preview server on FRONTEND_PORT (serves dist/, builds first)
# FRONTEND_PORT must match the port Vite listens on for the chosen mode:
#   dev:     5173
#   preview: 4173
# FRONTEND_NODE_ENV is forwarded to the container as NODE_ENV; use
# 'development' for dev mode and 'production' for preview mode.
FRONTEND_MODE=dev
FRONTEND_PORT=5173
FRONTEND_NODE_ENV=development

# Where Vite's /api/* proxy forwards. Defaults to the in-network backend
# service; override to point at a deployed API or a different port.
VITE_API_URL=http://backend:8080

# Hosts Vite's dev server is willing to serve. `all` is permissive (handy
# when reaching the container via tunnel/proxy URLs); narrow it down in
# locked-down environments.
VITE_ALLOWED_HOSTS=all

# Forces Vite's file watcher to poll instead of relying on inotify. Keep
# `true` on Windows/macOS docker hosts where the bind mount's FS events
# don't reach the Linux container.
CHOKIDAR_USEPOLLING=true

# ============================================================
# Backend (Spring Boot + Postgres)
# ============================================================

# Spring's embedded Tomcat port. Both the in-container Tomcat and the
# host port mapping read this so they always agree.
SERVER_PORT=8080

# JDWP remote-debug port. Mapped to the host so you can attach a
# debugger from IntelliJ / VS Code without entering the container.
DEBUG_PORT=5005

# --- Database ---
# DB_NAME is used both inside the postgres container (POSTGRES_DB) and
# in the backend's JDBC URL. DB_PORT only affects the host-side port
# mapping; inside the network, the backend always connects to db:5432.
DB_USER=foresight_user
DB_PASSWORD=change_me               # (required)
DB_NAME=foresight_db
DB_PORT=5432

# --- Auth (Clerk) — DEPRECATED, removed at end of Kinde migration ---
# Keep populated until the Kinde swap is fully merged, then delete this block.
# See docs/MIGRATION_CLERK_TO_KINDE.md for the cutover plan.
CLERK_ISSUER=https://sharp-sunbird-71.clerk.accounts.dev
CLERK_JWKS_URI=https://sharp-sunbird-71.clerk.accounts.dev/.well-known/jwks.json
CLERK_WEBHOOK_SIGNING_SECRET=whsec_replace_me
CLERK_SECRET_KEY=

# --- Auth (Kinde) — primary auth provider going forward ---
# Domain of your Kinde tenant (e.g. https://<your-subdomain>.kinde.com). Same value
# also serves as the JWT issuer (iss claim) on every session token.
KINDE_DOMAIN=https://your-subdomain.kinde.com
KINDE_ISSUER=https://your-subdomain.kinde.com
# JWKS endpoint — used by NimbusJwtDecoder both for validating session JWT signatures
# AND for verifying webhook payloads (Kinde signs webhooks with JWT, not HMAC, so the
# same JWKS handles both. No separate webhook signing secret exists).
KINDE_JWKS_URI=https://your-subdomain.kinde.com/.well-known/jwks
# OAuth2 client_credentials token endpoint used by KindeBackendClient to obtain an
# M2M access token for calls to the Kinde Management API.
KINDE_TOKEN_ENDPOINT=https://your-subdomain.kinde.com/oauth2/token
# Base URL of the Kinde Management API (fetch user profile, list orgs, etc.).
KINDE_MANAGEMENT_API_BASE_URL=https://your-subdomain.kinde.com/api/v1
# Credentials of the Machine-to-Machine app — Kinde Dashboard → Applications → Add app
# of type "Machine to Machine". Grant at least the `read:users` scope on the Kinde
# Management API. Secret is sensitive — never commit a real value.
KINDE_M2M_CLIENT_ID=
KINDE_M2M_CLIENT_SECRET=

# --- AI ---
ANTHROPIC_API_KEY=sk-ant-xxxxx      # (required)

# --- Analytics (PostHog) ---
# Server-side LLM observability. Each Anthropic call fires a $ai_generation event
# carrying model, usage (input/output tokens), latency, citations, and stop_reason.
# Distinct id = the authenticated user's Clerk id, so backend events correlate with
# frontend pageviews / UI events captured by posthog-js in the browser.
#
# Analytics is OFF by default everywhere. To turn it on for a given environment,
# set POSTHOG_ENABLED=true (backend) and/or VITE_POSTHOG_ENABLED=true (frontend) AND
# supply the matching key. Leaving the key blank with enabled=true is a hard backend
# startup failure (so misconfigs don't silently ship as no-ops); the frontend snippet
# silently installs a no-op stub when either flag or key is missing.
POSTHOG_ENABLED=false
POSTHOG_KEY=
POSTHOG_HOST=https://eu.i.posthog.com
VITE_POSTHOG_ENABLED=false
VITE_POSTHOG_KEY=
VITE_POSTHOG_HOST=https://eu.i.posthog.com

# --- CORS ---
# Comma-separated list of origins allowed to call the backend. Must
# include the frontend URL for the active mode (matches FRONTEND_PORT).
CORS_ALLOWED_ORIGINS=http://localhost:5173

# --- Email ---
# Provider: `logging` (no-op, dev default), `smtp`, etc.
EMAIL_PROVIDER=logging
EMAIL_FROM=no-reply@foresight.local
EMAIL_FROM_NAME=Foresight
APP_FRONTEND_URL=http://localhost:5173
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USERNAME=
MAIL_PASSWORD=
