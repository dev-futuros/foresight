# Template for environment files. Copy this to .env.local, .env.preview,
# .env.prod, etc. Example: `cp .env.example .env.local` then fill in real
# values. These files are git-ignored.

# --- Spring profile (matches application-<profile>.properties) ---
# Common values: local, dev, prod. Leave empty for the default profile.
SPRING_PROFILES_ACTIVE=local

# --- Compose profiles (comma-separated) ---
# `quality` brings up SonarQube. Leave empty in dev/prod where you don't want it.
COMPOSE_PROFILES=

# --- Frontend mode + port ---
# FRONTEND_MODE selects what the frontend container runs:
#   dev     → Vite dev server on FRONTEND_PORT (HMR, reads source directly)
#   preview → Vite preview server on FRONTEND_PORT (serves dist/, builds first)
# FRONTEND_PORT must match the port Vite listens on for the chosen mode:
#   dev:     5173
#   preview: 4173
# FRONTEND_NODE_ENV is forwarded to the container as NODE_ENV; use
# 'development' for dev mode and 'production' for preview mode.
FRONTEND_MODE=dev
FRONTEND_PORT=5173
FRONTEND_NODE_ENV=development

# --- Database ---
DB_USER=foresight_user
DB_PASSWORD=change_me

# --- Auth (Clerk) ---
# Issuer URL is the "Frontend API URL" from the Clerk Dashboard, no trailing slash.
# Dev instance: https://<your-app>.clerk.accounts.dev
# Prod (custom domain): https://clerk.<yourdomain>.com
CLERK_ISSUER=https://sharp-sunbird-71.clerk.accounts.dev
CLERK_JWKS_URI=https://sharp-sunbird-71.clerk.accounts.dev/.well-known/jwks.json
# Webhook signing secret from Clerk Dashboard → Webhooks → <endpoint> → Signing Secret.
CLERK_WEBHOOK_SIGNING_SECRET=whsec_replace_me
# Backend API secret key from Clerk Dashboard → API Keys → Secret Keys (sk_test_... / sk_live_...).
CLERK_SECRET_KEY=

# --- AI ---
ANTHROPIC_API_KEY=sk-ant-xxxxx

# --- CORS ---
# Comma-separated list of origins allowed to call the backend. Must
# include the frontend URL for the active mode (matches FRONTEND_PORT).
CORS_ALLOWED_ORIGINS=http://localhost:5173

# --- Frontend ---
# Public URL of the frontend (used by emails, share links, etc.). Must
# match the active FRONTEND_PORT.
APP_FRONTEND_URL=http://localhost:5173
