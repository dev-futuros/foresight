# Template for environment files. Copy this to .env.local, .env.dev, .env.prod, etc.
# Example: `cp .env.example .env.local` then fill in real values.
# These files are git-ignored.

# --- Spring profile (matches application-<profile>.properties) ---
# Common values: local, dev, prod. Leave empty for the default profile.
SPRING_PROFILES_ACTIVE=local

# --- Compose profiles (comma-separated) ---
# `quality` brings up SonarQube. Leave empty in dev/prod where you don't want it.
COMPOSE_PROFILES=quality

# --- Database ---
DB_USER=foresight_user
DB_PASSWORD=change_me

# --- Auth ---
JWT_SECRET=change_me_to_a_long_random_secret_min_32_chars

# --- AI ---
ANTHROPIC_API_KEY=sk-ant-xxxxx

# --- CORS ---
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000

# --- Email ---
# `logging` (default) writes tokens to backend logs. Set to `smtp` to deliver real emails
# through the spring.mail.* config (Gmail / SES / SendGrid / …).
EMAIL_PROVIDER=logging
EMAIL_FROM=no-reply@foresight.local
EMAIL_FROM_NAME=Foresight

# Frontend URL embedded into email links (verify, reset password, ...).
APP_FRONTEND_URL=http://localhost:5173

# SMTP credentials — required when EMAIL_PROVIDER=smtp.
# For Gmail: enable 2FA on the account, then create an app password at
# https://myaccount.google.com/apppasswords and paste it below (NOT the account password).
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USERNAME=your-account@gmail.com
MAIL_PASSWORD=your_16_char_app_password
