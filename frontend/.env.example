# Frontend env template. Copy to .env.local and fill in real values.
# .env* (except .env.example) is git-ignored.

# --- Auth (Clerk) — DEPRECATED, removed at end of Kinde migration ---
# See docs/MIGRATION_CLERK_TO_KINDE.md for the cutover plan.
VITE_CLERK_PUBLISHABLE_KEY=pk_test_replace_me

# --- Auth (Kinde) — primary auth provider going forward ---
# Domain of your Kinde tenant. Same value the backend reads as KINDE_DOMAIN.
VITE_KINDE_DOMAIN=https://your-subdomain.kinde.com
# Client ID of the Front-end and mobile app created in Kinde Dashboard → Applications.
# Public by design (it ships in the browser bundle).
VITE_KINDE_CLIENT_ID=
# Where Kinde redirects after a successful login. Must be on the Allowed Callback URLs
# list of the Kinde app. Port 5173 = Vite dev (npm run dev); 4173 = Vite preview.
VITE_KINDE_REDIRECT_URI=http://localhost:5173/callback
# Where Kinde redirects after logout. Must be on the Allowed Logout Redirect URLs list.
VITE_KINDE_LOGOUT_REDIRECT_URI=http://localhost:5173

# Frontend analytics is OFF by default. To turn it on for a build, set
# VITE_POSTHOG_ENABLED=true AND supply VITE_POSTHOG_KEY. With either missing the
# index.html snippet installs a no-op stub on window.posthog and never fetches
# the real array.js, so call sites can call posthog.* unconditionally.
VITE_POSTHOG_ENABLED=false
# PostHog project API key (looks like `phc_...`). Same key the backend reads from
# POSTHOG_KEY — PostHog scopes events by project, not by SDK. Baked into index.html
# at build time via Vite's `%VITE_POSTHOG_KEY%` substitution.
VITE_POSTHOG_KEY=
# Ingestion host. Defaults to EU cloud — set to https://us.i.posthog.com if the
# project lives on the US instance.
VITE_POSTHOG_HOST=https://eu.i.posthog.com
