# Frontend env template. Copy to .env.local and fill in real values.
# .env* (except .env.example) is git-ignored.

# --- Auth (Kinde) ---
# Domain of your Kinde tenant. Same value the backend reads as KINDE_DOMAIN.
VITE_KINDE_DOMAIN=https://your-subdomain.kinde.com
# Client ID of the Front-end and mobile app created in Kinde Dashboard → Applications.
# Public by design (it ships in the browser bundle).
VITE_KINDE_CLIENT_ID=
# Where Kinde redirects after a successful login. Must be on the Allowed Callback URLs
# list of the Kinde app. Port 5173 = Vite dev (npm run dev); 4173 = Vite preview.
VITE_KINDE_REDIRECT_URI=http://localhost:5173/callback
# Where Kinde redirects after logout. Must be on the Allowed Logout Redirect URLs list.
# Pointing this at /logged-out makes Kinde skip its stock "you've signed out"
# template and land users on our own branded LoggedOutRoute instead.
VITE_KINDE_LOGOUT_REDIRECT_URI=http://localhost:5173/logged-out

# --- Error tracking (Sentry) ---
# DSN from the Sentry project (Settings → Client Keys (DSN)). Leave unset
# in local dev and ephemeral previews — initSentry() is a silent no-op
# without a DSN and the app runs normally with errors going to the
# browser console only.
VITE_SENTRY_DSN=
# Optional environment override. Defaults to import.meta.env.MODE
# (development/production). Useful to distinguish staging from prod when
# both build with NODE_ENV=production.
VITE_SENTRY_ENVIRONMENT=
# Optional release tag. CI typically sets this to the git SHA so Sentry
# can group errors by deploy and auto-resolve them when a fix lands.
VITE_APP_VERSION=

# --- Sentry source-map upload (BUILD-TIME, not runtime) ---
# These are read by @sentry/vite-plugin during `npm run build` to upload
# the generated source maps so production stack traces show real symbol
# names instead of minified blobs. NOT prefixed with VITE_ because they
# must NOT ship to the browser. Set only in CI (Railway build env).
#
# When SENTRY_AUTH_TOKEN is unset, the plugin no-ops at build time — so
# local builds work without these.
# SENTRY_AUTH_TOKEN=
# SENTRY_ORG=futuros
# SENTRY_PROJECT=futuros-fe

# --- Product analytics (Mixpanel) ---
# Project token from Mixpanel (Project Settings → Access Keys → Project
# Token). Public by design — safe to ship in the browser bundle. EU
# project: the SDK is pinned to api-eu.mixpanel.com in code, so the
# project itself must also be provisioned in the EU region (check at
# eu.mixpanel.com — if your URL is app.mixpanel.com, it's US and the
# SDK will reject events).
#
# Leave unset locally so dev events don't pollute the prod project —
# initMixpanel() is a silent no-op without a token. Only Railway prod
# should have this set.
VITE_MIXPANEL_TOKEN=
# Optional: VITE_MIXPANEL_DEBUG=1 flips the SDK's debug flag, which
# logs every track() call to the browser console. Useful when adding
# new events; off by default.
VITE_MIXPANEL_DEBUG=
